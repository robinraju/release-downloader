{
  "name": "release-downloader",
  "version": "1.0.0",
  "author": "Robin Raju",
  "license": "MIT",
  "type": "module",
  "private": true,
  "description": "Github action to download release assets",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin \"@rollup/plugin-typescript={sourceMap:false}\"",
    "package:watch": "npm run package -- --watch",
    "prepare": "husky",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run package",
    "verify": "npm run format:check && npm run lint && npm run test && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:robinraju/release-downloader.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "github release download"
  ],
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/io": "^1.1.3",
    "minimatch": "^10.2.5",
    "node-stream-zip": "^1.15.0",
    "tar": "^7.5.13",
    "typed-rest-client": "^2.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/tar": "^7.0.87",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nock": "^14.0.12",
    "prettier": "3.8.2",
    "prettier-eslint": "^16.4.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.27.0",
    "ts-jest": "^29.4.9",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "6.0.3"
  }
}
