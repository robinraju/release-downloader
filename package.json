{
  "name": "release-downloader",
  "version": "1.0.0",
  "author": "Robin Raju",
  "license": "MIT",
  "private": true,
  "description": "Github action to download release assets",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "npx jest",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rimraf ./dist && npx ncc build src/main.ts -o dist --license licenses.txt",
    "package:watch": "npm run package -- --watch",
    "test": "npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run package",
    "verify": "npm run format:check && npm run lint && npm run test && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:robinraju/release-downloader.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "github release download"
  ],
  "jest": {
    "preset": "ts-jest",
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 100,
        "lines": 95,
        "statements": 95
      }
    }
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/io": "^1.1.3",
    "minimatch": "^10.2.5",
    "node-stream-zip": "^1.15.0",
    "tar": "^7.5.13",
    "typed-rest-client": "^2.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.2",
    "@types/tar": "^7.0.87",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^5.1.8",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "nock": "^14.0.11",
    "prettier": "3.5.3",
    "prettier-eslint": "^16.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.2.6",
    "typescript": "5.8.2"
  }
}
